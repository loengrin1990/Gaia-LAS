{
  "config_version": 1,
  "server": {
    "host": "127.0.0.1",
    "port": 8787
  },
  "paths": {
    "vault": "${HOME}/Documents/Obsidian Vault",
    "projects": "${VAULT}/Проекты",
    "service_docs": "${HOME}/Documents/Obsidian Gaia",
    "runs": "${APP_DIR}/runs",
    "exports": "${APP_DIR}/exports",
    "storage": "${APP_DIR}/storage",
    "obsidian_work": "${WORKSPACE}/Obsidian_System_Work",
    "transcriber": "${HOME}/path/to/transcribe",
    "lm_studio_launcher": "${HOME}/path/to/launch-lm-studio.command",
    "transcriber_launcher": "${HOME}/path/to/launch-transcriber.command"
  },
  "endpoints": {
    "lm_studio": "http://127.0.0.1:1234/v1/chat/completions"
  },
  "local_llm": {
    "prompt_char_limit": 16000,
    "max_tokens": 1200,
    "default_provider": "lm_studio",
    "providers": {
      "lm_studio": {
        "type": "openai_compatible",
        "endpoint": "http://127.0.0.1:1234/v1/chat/completions",
        "model": "local-model",
        "enabled": true
      },
      "ollama_local": {
        "type": "ollama",
        "endpoint": "http://127.0.0.1:11434/api/chat",
        "model": "qwen3:8b",
        "thinking": false,
        "json_mode": true,
        "context_length": 8192,
        "enabled": false
      }
    },
    "routes": {
      "hearth": {"provider": "lm_studio", "prompt_char_limit": 16000, "max_tokens": 900},
      "lore_query_rewrite": {"provider": "lm_studio", "prompt_char_limit": 5000, "max_tokens": 160},
      "lore_rerank": {"provider": "lm_studio", "prompt_char_limit": 8000, "max_tokens": 180},
      "lore_gap_detector": {"provider": "lm_studio", "prompt_char_limit": 6000, "max_tokens": 180},
      "veil_review": {"provider": "lm_studio", "prompt_char_limit": 7000, "max_tokens": 200},
      "context_compiler": {"provider": "lm_studio", "prompt_char_limit": 12000, "max_tokens": 700},
      "scribe_classifier": {"provider": "lm_studio", "prompt_char_limit": 9000, "max_tokens": 400},
      "project_health": {"provider": "lm_studio", "prompt_char_limit": 6000, "max_tokens": 300}
    }
  },
  "processing": {
    "analyze_job_timeout_seconds": 900,
    "transcription_timeout_seconds": 600,
    "completed_job_retention_seconds": 1800
  },
  "retention": {
    "runs_days": 7,
    "journals_days": 30,
    "audit_days": 30,
    "conversations_days": 90,
    "temporary_hours": 24,
    "operation_metadata_days": 180,
    "cleanup_on_startup": false
  },
  "lore": {
    "query_rewrite": false,
    "query_rewrite_timeout_seconds": 4,
    "semantic_rerank": false,
    "rerank_candidates": 24,
    "rerank_timeout_seconds": 45,
    "gap_detector": false,
    "gap_detector_timeout_seconds": 4,
    "veil_llm_review": false,
    "veil_llm_review_timeout_seconds": 4,
    "scribe_candidate_classifier": false,
    "scribe_classifier_timeout_seconds": 5,
    "project_health_llm": false,
    "project_health_timeout_seconds": 5
  }
}
